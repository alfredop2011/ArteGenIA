    "@sentry/nextjs": "^10.57.0",
    "@stripe/stripe-js": "^9.8.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "fabric": "^7.3.1",
    "framer-motion": "^12.39.0",
    "gsap": "^3.15.0",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.14.0",
    "next": "16.2.6",
    "posthog-js": "^1.383.2",
    "posthog-node": "^5.38.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.4",
    "sharp": "^0.34.5",
    "stripe": "^22.2.0",
    "swiper": "^12.1.4"
