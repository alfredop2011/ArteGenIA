    "r2:cors": "node --env-file=.env.local scripts/r2-cors-apply.mjs",
    "r2:cors:check": "node --env-file=.env.local scripts/r2-cors-apply.mjs --check",
    "r2:cleanup": "node --env-file=.env.local scripts/r2-cleanup-orphans.mjs",
    "r2:cleanup:apply": "node --env-file=.env.local scripts/r2-cleanup-orphans.mjs --apply",
    "db:backup": "node --env-file=.env.local scripts/db-backup.mjs",
    "db:backup:list": "node --env-file=.env.local scripts/db-backup.mjs --list",
    "stripe:backfill": "node --env-file=.env.local scripts/stripe-backfill-customer-id.mjs",
    "stripe:backfill:apply": "node --env-file=.env.local scripts/stripe-backfill-customer-id.mjs --apply",
    "brand:export": "node scripts/brand-export.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
