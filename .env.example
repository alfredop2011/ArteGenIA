# ===========================================================================
# ArteGenIA — plantilla de variables de entorno
# ---------------------------------------------------------------------------
# Copia este archivo a .env.local (NO lo subas con valores reales) y rellena.
# En Vercel: añade las mismas en Production + Preview + Development.
# Marcadas [BLOQUEANTE] = sin ellas algo se rompe en producción.
# ===========================================================================

# ── Dominio canónico ───────────────────────────────────────────────────────
# Clave para SEO: canonical, sitemap, robots y OG URLs cuelgan de aquí.
NEXT_PUBLIC_SITE_URL=https://artegenia.com          # [BLOQUEANTE SEO]
NEXT_PUBLIC_APP_URL=https://artegenia.com           # CTAs de los emails

# ── Supabase (auth + BD) ───────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=                           # [BLOQUEANTE]
NEXT_PUBLIC_SUPABASE_ANON_KEY=                      # [BLOQUEANTE]
SUPABASE_SERVICE_ROLE_KEY=                          # [BLOQUEANTE] server-only, NUNCA al cliente

# ── Stripe (pagos) ─────────────────────────────────────────────────────────
# En producción usa claves live (sk_live_ / whsec_ del endpoint live) y
# recrea los price IDs en modo live — los de test NO funcionan en live.
STRIPE_SECRET_KEY=                                  # [BLOQUEANTE] sk_live_... en prod
STRIPE_WEBHOOK_SECRET=                              # [BLOQUEANTE] whsec_... del endpoint live
STRIPE_PRO_PRICE_ID=                                # [BLOQUEANTE] price_... mensual
STRIPE_PRO_PRICE_ID_YEARLY=                         # price_... anual (cae a mensual si falta)
STRIPE_ENTERPRISE_PRICE_ID=                         # opcional (Enterprise bloqueado hoy)
STRIPE_ENTERPRISE_PRICE_ID_YEARLY=                  # opcional
STRIPE_TRIAL_DAYS=0                                 # opcional, >0 reactiva el trial

# ── Cloudflare R2 (almacenamiento de imágenes) ─────────────────────────────
R2_ACCOUNT_ID=                                      # [BLOQUEANTE]
R2_ACCESS_KEY_ID=                                   # [BLOQUEANTE]
R2_SECRET_ACCESS_KEY=                               # [BLOQUEANTE]
R2_BUCKET_NAME=                                     # [BLOQUEANTE]
R2_PUBLIC_URL=                                      # [BLOQUEANTE] requiere política CORS (ver AGENTS.md)

# ── Resend (email transaccional) ───────────────────────────────────────────
RESEND_API_KEY=                                     # [BLOQUEANTE] o emails NO-OP
RESEND_FROM_EMAIL=ArteGenIA <hola@artegenia.com>    # dominio verificado en Resend

# ── Cron (Vercel) ──────────────────────────────────────────────────────────
CRON_SECRET=                                        # [BLOQUEANTE] sin esto los cron dan 403 (fail-closed)

# ── IA / procesamiento de imagen ───────────────────────────────────────────
FAL_KEY=                                            # Fal.ai (generación, segmentación)
REMOVE_BG_API_KEY=                                  # remove.bg (quitar fondo)
REPLICATE_API_TOKEN=                                # Replicate (modelos extra)
ANTHROPIC_API_KEY=                                  # asistente IA / wizard
OCR_PROVIDER=                                       # proveedor OCR (opcional)

# ── Analytics ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
